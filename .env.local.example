# Sthyra Command Center — environment
# Copy to .env.local and fill from the Supabase dashboard (Project Settings -> API)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose to the browser. Used to bootstrap verified users into public.profiles.
SUPABASE_SERVICE_ROLE_KEY=

# KesarCloud Omega gateway — powers the AI Assistant.
# Preferred: the owner sets the key in the app at Settings -> AI Assistant (encrypted in Supabase Vault).
# OMEGA_API_KEY below is an OPTIONAL server-side override (e.g. for cron) and wins if set. Never exposed to the browser.
OMEGA_API_KEY=
OMEGA_BASE_URL=https://omega.kesarcloud.in/v1
